# HARDCODED STACKS Environment Configuration

# Analytics & Tracking
VITE_GOOGLE_ANALYTICS_ID=G_XXXXXXXXXX
VITE_ENABLE_ANALYTICS=true

# Environment
VITE_ENVIRONMENT=production

# API / Backend (if needed in future)
VITE_API_URL=https://api.hardcoded-stacks.com

# Feature Flags
VITE_ENABLE_DEBUG_CONSOLE=false
VITE_ENABLE_PERFORMANCE_MONITORING=true

# PWA Settings
VITE_PWA_ENABLED=true
VITE_SERVICE_WORKER_UPDATE_INTERVAL=3600000

# Deployment & Build
VITE_DEPLOYMENT_TARGET=vercel
VITE_BUILD_VERSION=1.0.0
